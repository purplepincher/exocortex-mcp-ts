{
  "name": "exocortex-mcp-ts",
  "version": "1.0.1",
  "description": "TypeScript implementation of the Exocortex MCP server + REST API — the web-native interface to the notebook runtime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --verbose --forceExit",
    "start": "node dist/index.js",
    "start:mcp": "node dist/index.js --mcp",
    "start:rest": "node dist/index.js --rest --port 3000",
    "lint": "tsc --noEmit"
  },
  "keywords": ["mcp", "exocortex", "notebook", "machine-learning", "rest-api", "json-rpc"],
  "author": "purplepincher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/purplepincher/exocortex-mcp-ts.git"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0"
  }
}
